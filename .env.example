# ─── Resend (email service) ──────────────────────────────────────────
# Sign up at https://resend.com – free tier: 3,000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address for emails sent to subscribers.
# For testing you can use:  Fabian Tejada <onboarding@resend.dev>
# For production, verify your domain in Resend and use your own:
FROM_EMAIL=Fabian Tejada <info@yourdomain.com>

# (Optional) Your own email — receive a notification for every new sign-up
NOTIFY_EMAIL=fabianos04@icloud.com

# ─── Site URL ────────────────────────────────────────────────────────
# Used to build the PDF download link inside the email.
# On Vercel this is set automatically via VERCEL_URL, but you can override it.
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app
